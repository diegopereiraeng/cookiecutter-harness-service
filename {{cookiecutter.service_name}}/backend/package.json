{
  "name": "{{ cookiecutter.service_name }}-api",
  "version": "1.0.0",
  "description": "{{ cookiecutter.service_description }}",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --coverage --coverageReporters=json-summary",
    "test:ci": "jest --ci --reporters=default --reporters=jest-junit --passWithNoTests",
    "generate:spec": "tsx src/scripts/generate-spec.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "supertest": "^6.3.4",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "swagger-jsdoc": "^6.2.8",
    "js-yaml": "^4.1.0",
    "@types/js-yaml": "^4.0.9"
  },
  "jest-junit": {
    "outputDirectory": "test-results",
    "outputName": "junit.xml"
  }
}
